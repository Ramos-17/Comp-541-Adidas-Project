import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import warnings

warnings.filterwarnings('ignore')

from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error

# 1. LOAD DATA (CSV)
file_path = r"AdidasDataset2023to2025.csv"
df = pd.read_csv(file_path)

# 2. PREPARE DATA
df["Order_Date"] = pd.to_datetime(df["Order_Date"], errors="coerce")
df = df.dropna(subset=["Order_Date"])

# 3. AGGREGATE TO DAILY BUSYNESS
daily = df.groupby("Order_Date").agg({
    "Order_ID": "count",
    "Units_Sold": "sum",
    "Revenue": "sum"
}).rename(columns={
    "Order_ID": "Num_Orders",
    "Units_Sold": "Total_Units",
    "Revenue": "Total_Revenue"
})

daily = daily.resample('D').sum().fillna(0)

# 4. FEATURE ENGINEERING
daily["lag_1"] = daily["Num_Orders"].shift(1)
daily["lag_7"] = daily["Num_Orders"].shift(7)
daily["rolling_mean_7"] = daily["Num_Orders"].rolling(window=7).mean()

# Time features
daily["day_of_week"] = daily.index.dayofweek
daily["month"] = daily.index.month
daily["day"] = daily.index.day

daily = daily.dropna()

# 5. FEATURES & TARGET
X = daily.drop(columns=["Num_Orders", "Total_Units", "Total_Revenue"])
y = daily["Num_Orders"]

# 6. TIME-BASED SPLIT
split_date = "2025-01-01"

X_train = X[X.index < split_date]
X_test = X[X.index >= split_date]
y_train = y[y.index < split_date]
y_test = y[y.index >= split_date]

# 7. BUILD & TRAIN RANDOM FOREST (REFINED PARAMETERS)
# These parameters are tuned to minimize the Train/Test gap, took forever
chosen_depth = 6
model = RandomForestRegressor(
    n_estimators=300,
    max_depth=chosen_depth,
    min_samples_leaf=15,
    max_features=0.7,
    max_samples=0.7,
    random_state=42
)

print("Training Refined Balanced Model...")
model.fit(X_train, y_train)
print("Training Complete!")

# 8. PREDICTIONS & EVALUATION
train_pred = model.predict(X_train)
test_pred = model.predict(X_test)

train_rmse = np.sqrt(mean_squared_error(y_train, train_pred))
test_rmse = np.sqrt(mean_squared_error(y_test, test_pred))

print(f"Train RMSE: {round(train_rmse, 4)}")
print(f"Test RMSE: {round(test_rmse, 4)}")
print(f"Gap (Overfit Level): {round(abs(train_rmse - test_rmse), 4)}")

# 8.5 VISUALIZE THE LEARNING CURVE
print("Generating Refined Learning Curve...")
depths = range(1, 25)
train_errors = []
test_errors = []

for d in depths:
    temp_model = RandomForestRegressor(
        n_estimators=100,
        max_depth=d,
        min_samples_leaf=15,
        max_features=0.7,
        max_samples=0.7,
        random_state=42
    )
    temp_model.fit(X_train, y_train)
    train_errors.append(np.sqrt(mean_squared_error(y_train, temp_model.predict(X_train))))
    test_errors.append(np.sqrt(mean_squared_error(y_test, temp_model.predict(X_test))))

plt.figure(figsize=(10, 5))
plt.plot(depths, train_errors, label='Train Error', marker='o', color='blue', alpha=0.7)
plt.plot(depths, test_errors, label='Test Error', marker='s', color='darkorange', alpha=0.7)

plt.fill_between(depths, train_errors, test_errors, color='green', alpha=0.1, label='Refined Gap')
plt.axvline(x=chosen_depth, color='red', linestyle='--', label=f'Refined Depth ({chosen_depth})')

plt.title("Learning Curve: Reaching Perfect Generalization")
plt.xlabel("Max Tree Depth")
plt.ylabel("RMSE")
plt.legend()
plt.grid(True, linestyle='--', alpha=0.5)
plt.tight_layout()
plt.show()

# 9. VISUALIZATIONS

# Actual vs Predicted
plt.figure(figsize=(10, 5))
plt.plot(y_test.index, y_test, label="Actual Orders", alpha=0.3, color='gray')
plt.plot(y_test.index, test_pred, label="Predicted (Refined RF)", color='darkblue', linewidth=2)
plt.title("2025 Prediction: Refined & Stable")
plt.xlabel("Date")
plt.ylabel("Number of Orders")
plt.legend()
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# Feature Importance
importances = pd.Series(model.feature_importances_, index=X.columns).sort_values()
plt.figure(figsize=(8, 4))
importances.plot(kind='barh', color='darkcyan')
plt.title("What truly drives Adidas orders? (Refined)")
plt.show()

#  Scatter Plot
plt.figure()
plt.scatter(y_test, test_pred, alpha=0.5, color='darkgreen')
max_val = max(max(y_test), max(test_pred))
plt.plot([0, max_val], [0, max_val], color='red', linestyle='--')
plt.xlabel("Actual Orders")
plt.ylabel("Predicted Orders")
plt.title("Actual vs Predicted (Refined)")
plt.show()


# 10. FUTURE PREDICTION FUNCTION

def predict_future(date_str):
    date = pd.to_datetime(date_str)
    last_row = daily.iloc[-1]

    new_data = pd.DataFrame({
        "lag_1": [last_row["Num_Orders"]],
        "lag_7": [daily["Num_Orders"].iloc[-7]],
        "rolling_mean_7": [daily["Num_Orders"].iloc[-7:].mean()],
        "day_of_week": [date.dayofweek],
        "month": [date.month],
        "day": [date.day]
    })

    prediction = model.predict(new_data)[0]
    print(f"\n=> Predicted busyness for {date_str}: {prediction:.2f} orders")

next_day = (daily.index[-1] + pd.Timedelta(days=1)).strftime('%Y-%m-%d')
predict_future(next_day)
